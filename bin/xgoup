#!/usr/bin/env bash

set -euo pipefail

XGOUP_VERSION="0.1.0"
TOOL_HOME="${XGOUP_HOME:-$HOME/.xgoup}"
TOOLCHAINS_DIR="$TOOL_HOME/toolchains"
META_DIR="$TOOL_HOME/metadata"
CONFIG_FILE="$TOOL_HOME/config.toml"
PROJECT_FILE="xgo-toolchain.toml"
DEFAULT_SOURCE_REPO="https://github.com/goplus/xgo.git"

log() {
  printf '[xgoup] %s\n' "$*"
}

warn() {
  printf '[xgoup] WARN: %s\n' "$*" >&2
}

err() {
  printf '[xgoup] ERROR: %s\n' "$*" >&2
}

die() {
  err "$*"
  exit 1
}

usage() {
  cat <<'USAGE'
Usage:
  xgoup init
  xgoup install <name> [--method <standard|source|linked>] [--ref <git-ref>] [--repo <url>] [--path <dir>] [--force]
  xgoup update [name]
  xgoup list [--json]
  xgoup remove <name> [--purge]
  xgoup toolchain install <name> [--method <standard|source|linked>] [--ref <git-ref>] [--repo <url>] [--path <dir>] [--force]
  xgoup toolchain update [name]
  xgoup toolchain list [--json]
  xgoup toolchain remove <name> [--purge]
  xgoup default <name>
  xgoup which [--toolchain <name>]
  xgoup env [--toolchain <name>] [--shell <sh|zsh|fish|powershell>]
  xgoup doctor

Compatibility aliases:
  xgoup toolchain <subcmd>  (kept for grouping; top-level commands are preferred)

Environment:
  XGOUP_HOME       Home directory (default: ~/.xgoup)
  XGO_TOOLCHAIN    Runtime toolchain override for `which`/`env`
USAGE
}

require_cmd() {
  command -v "$1" >/dev/null 2>&1 || die "missing required command: $1"
}

escape_sq() {
  printf '%s' "$1" | sed "s/'/'\\\\''/g"
}

ensure_dirs() {
  mkdir -p "$TOOLCHAINS_DIR" "$META_DIR"
}

valid_name() {
  [[ "$1" =~ ^[A-Za-z0-9._-]+$ ]]
}

meta_file() {
  printf '%s/%s.env\n' "$META_DIR" "$1"
}

have_toolchain() {
  [[ -f "$(meta_file "$1")" ]]
}

write_meta() {
  local name="$1"
  local mf
  mf="$(meta_file "$name")"

  {
    printf "NAME='%s'\n" "$(escape_sq "${NAME:-$name}")"
    printf "KIND='%s'\n" "$(escape_sq "${KIND:-}")"
    printf "ROOT_PATH='%s'\n" "$(escape_sq "${ROOT_PATH:-}")"
    printf "XGO_BIN='%s'\n" "$(escape_sq "${XGO_BIN:-}")"
    printf "XGOROOT_VALUE='%s'\n" "$(escape_sq "${XGOROOT_VALUE:-}")"
    printf "MANAGED='%s'\n" "$(escape_sq "${MANAGED:-false}")"
    printf "REPO='%s'\n" "$(escape_sq "${REPO:-}")"
    printf "REF='%s'\n" "$(escape_sq "${REF:-}")"
    printf "COMMIT='%s'\n" "$(escape_sq "${COMMIT:-}")"
    printf "VERSION='%s'\n" "$(escape_sq "${VERSION:-}")"
  } >"$mf"
}

load_meta() {
  local name="$1"
  local mf
  mf="$(meta_file "$name")"
  [[ -f "$mf" ]] || die "toolchain not found: $name"

  unset NAME KIND ROOT_PATH XGO_BIN XGOROOT_VALUE MANAGED REPO REF COMMIT VERSION
  # shellcheck disable=SC1090
  source "$mf"

  [[ -n "${NAME:-}" ]] || NAME="$name"
}

meta_names() {
  ensure_dirs
  find "$META_DIR" -maxdepth 1 -type f -name '*.env' -print 2>/dev/null \
    | sed -E 's#.*/##; s#\.env$##' \
    | sort
}

default_toolchain() {
  if [[ -f "$CONFIG_FILE" ]]; then
    awk -F'"' '/^default_toolchain[[:space:]]*=/{print $2; exit}' "$CONFIG_FILE"
  fi
}

set_default_toolchain() {
  local name="$1"
  have_toolchain "$name" || die "toolchain not found: $name"
  write_config "$name"
  log "default toolchain set to '$name'"
}

write_config() {
  ensure_dirs

  local default_name="${1:-$(default_toolchain)}"
  if [[ -z "$default_name" ]]; then
    local first=""
    first="$(meta_names | head -n 1 || true)"
    default_name="$first"
  fi

  {
    echo "version = 1"
    printf 'default_toolchain = "%s"\n' "$default_name"
    printf 'last_update_check = "%s"\n\n' "$(date -u +"%Y-%m-%dT%H:%M:%SZ")"

    echo "[settings]"
    echo "auto_self_update = true"
    echo "auto_path_hint = true"
    echo "telemetry = false"
    echo

    echo "[registries]"
    printf 'source_repo = "%s"\n' "$DEFAULT_SOURCE_REPO"
    echo 'release_base_url = "https://github.com/<org>/xgoup/releases/download"'
    echo

    local n
    while IFS= read -r n; do
      [[ -n "$n" ]] || continue
      load_meta "$n"
      printf '[toolchains.%s]\n' "$n"
      printf 'kind = "%s"\n' "$KIND"
      printf 'path = "%s"\n' "$ROOT_PATH"
      printf 'managed = %s\n' "$MANAGED"
      [[ -n "$VERSION" ]] && printf 'version = "%s"\n' "$VERSION"
      [[ -n "$REPO" ]] && printf 'repo = "%s"\n' "$REPO"
      [[ -n "$REF" ]] && printf 'ref = "%s"\n' "$REF"
      [[ -n "$COMMIT" ]] && printf 'commit = "%s"\n' "$COMMIT"
      echo
    done < <(meta_names)
  } >"$CONFIG_FILE"
}

cmd_init() {
  ensure_dirs
  [[ -f "$CONFIG_FILE" ]] || write_config ""
  log "initialized home: $TOOL_HOME"
}

detect_version_from_xgo() {
  local bin="$1"
  local out
  out="$($bin version 2>/dev/null || true)"
  if [[ -n "$out" ]]; then
    echo "$out" | head -n 1 | sed -E 's/[[:space:]]+/ /g'
  fi
}

maybe_set_default_if_empty() {
  local current
  current="$(default_toolchain || true)"
  if [[ -z "$current" ]]; then
    write_config "$1"
    log "no default found, set '$1' as default"
  fi
}

install_source() {
  local name="$1"
  local repo="$2"
  local ref="$3"
  local force="$4"

  require_cmd git
  require_cmd go
  ensure_dirs

  local target="$TOOLCHAINS_DIR/$name"
  if [[ -e "$target" ]]; then
    if [[ "$force" == "true" ]]; then
      rm -rf "$target"
    else
      die "toolchain '$name' already exists; use --force to replace"
    fi
  fi

  log "cloning $repo -> $target"
  git clone "$repo" "$target"

  if [[ -n "$ref" ]]; then
    log "checking out $ref"
    git -C "$target" checkout "$ref"
  fi

  log "building toolchain via ./all.bash"
  (
    cd "$target"
    ./all.bash
  )

  local bin="$target/bin/xgo"
  [[ -x "$bin" ]] || die "build finished but xgo not found: $bin"

  NAME="$name"
  KIND="source"
  ROOT_PATH="$target"
  XGO_BIN="$bin"
  XGOROOT_VALUE="$target"
  MANAGED="true"
  REPO="$repo"
  REF="$ref"
  COMMIT="$(git -C "$target" rev-parse HEAD 2>/dev/null || true)"
  VERSION="$(detect_version_from_xgo "$bin")"
  write_meta "$name"
  write_config ""
  maybe_set_default_if_empty "$name"

  log "installed source toolchain '$name'"
}

best_effort_detect_xgoroot() {
  local bin="$1"
  local candidate=""

  if [[ -n "${XGOROOT:-}" && -x "$XGOROOT/bin/xgo" ]]; then
    echo "$XGOROOT"
    return 0
  fi

  candidate="$($bin env XGOROOT 2>/dev/null || true)"
  if [[ -n "$candidate" && -x "$candidate/bin/xgo" ]]; then
    echo "$candidate"
    return 0
  fi

  local parent
  parent="$(cd "$(dirname "$bin")/.." 2>/dev/null && pwd || true)"
  if [[ -n "$parent" && -x "$parent/bin/xgo" ]]; then
    echo "$parent"
    return 0
  fi

  return 1
}

install_standard() {
  local name="$1"
  local force="$2"

  ensure_dirs
  if have_toolchain "$name" && [[ "$force" != "true" ]]; then
    die "toolchain '$name' already exists; use --force to replace"
  fi

  local os
  os="$(uname -s | tr '[:upper:]' '[:lower:]')"

  if [[ "$os" == "darwin" ]]; then
    if command -v brew >/dev/null 2>&1; then
      if brew ls --versions xgo >/dev/null 2>&1; then
        log "updating xgo via brew"
        brew upgrade xgo
      else
        log "installing xgo via brew"
        brew install xgo
      fi
    else
      die "standard method on macOS expects Homebrew (brew)"
    fi
  else
    require_cmd go
    warn "standard method fallback on non-macOS uses: go install github.com/goplus/xgo/cmd/xgo@latest"
    go install github.com/goplus/xgo/cmd/xgo@latest
  fi

  local bin
  bin="$(command -v xgo || true)"
  [[ -n "$bin" ]] || die "xgo binary not found in PATH after standard install"

  local detected_root=""
  detected_root="$(best_effort_detect_xgoroot "$bin" || true)"

  NAME="$name"
  KIND="standard"
  ROOT_PATH="${detected_root:-$(cd "$(dirname "$bin")/.." && pwd)}"
  XGO_BIN="$bin"
  XGOROOT_VALUE="$detected_root"
  MANAGED="true"
  REPO=""
  REF=""
  COMMIT=""
  VERSION="$(detect_version_from_xgo "$bin")"
  write_meta "$name"
  write_config ""
  maybe_set_default_if_empty "$name"

  if [[ -z "$detected_root" ]]; then
    warn "unable to reliably detect XGOROOT for standard install; run may still work if xgo resolves its own root"
  fi

  log "installed standard toolchain '$name'"
}

install_linked() {
  local name="$1"
  local path="$2"
  local force="$3"

  ensure_dirs
  [[ -n "$path" ]] || die "linked method requires --path <dir>"

  local abs
  abs="$(cd "$path" 2>/dev/null && pwd || true)"
  [[ -n "$abs" && -d "$abs" ]] || die "invalid linked path: $path"

  local bin="$abs/bin/xgo"
  [[ -x "$bin" ]] || die "linked path missing executable xgo: $bin"

  if have_toolchain "$name" && [[ "$force" != "true" ]]; then
    die "toolchain '$name' already exists; use --force to replace"
  fi

  NAME="$name"
  KIND="linked"
  ROOT_PATH="$abs"
  XGO_BIN="$bin"
  XGOROOT_VALUE="$abs"
  MANAGED="false"
  REPO=""
  REF=""
  COMMIT=""
  VERSION="$(detect_version_from_xgo "$bin")"
  write_meta "$name"
  write_config ""
  maybe_set_default_if_empty "$name"

  log "linked toolchain '$name' -> $abs"
}

cmd_toolchain_install() {
  [[ $# -ge 1 ]] || die "toolchain install requires <name>"
  local name="$1"
  shift

  valid_name "$name" || die "invalid toolchain name: $name"

  local method="standard"
  local repo="$DEFAULT_SOURCE_REPO"
  local ref=""
  local link_path=""
  local force="false"

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --method)
        [[ $# -ge 2 ]] || die "--method requires value"
        method="$2"
        shift 2
        ;;
      --repo)
        [[ $# -ge 2 ]] || die "--repo requires value"
        repo="$2"
        shift 2
        ;;
      --ref)
        [[ $# -ge 2 ]] || die "--ref requires value"
        ref="$2"
        shift 2
        ;;
      --path)
        [[ $# -ge 2 ]] || die "--path requires value"
        link_path="$2"
        shift 2
        ;;
      --force)
        force="true"
        shift
        ;;
      *)
        die "unknown option for toolchain install: $1"
        ;;
    esac
  done

  case "$method" in
    source) install_source "$name" "$repo" "$ref" "$force" ;;
    standard) install_standard "$name" "$force" ;;
    linked) install_linked "$name" "$link_path" "$force" ;;
    *) die "unknown method: $method" ;;
  esac
}

update_source() {
  local name="$1"
  load_meta "$name"

  require_cmd git
  require_cmd go

  [[ -d "$ROOT_PATH/.git" ]] || die "source toolchain is not a git checkout: $ROOT_PATH"

  log "updating source toolchain '$name'"
  git -C "$ROOT_PATH" fetch --tags --prune

  local branch
  branch="$(git -C "$ROOT_PATH" rev-parse --abbrev-ref HEAD)"
  if [[ "$branch" != "HEAD" ]]; then
    git -C "$ROOT_PATH" pull --ff-only
  else
    warn "detached HEAD for '$name'; skip pull"
  fi

  (
    cd "$ROOT_PATH"
    ./all.bash
  )

  XGO_BIN="$ROOT_PATH/bin/xgo"
  [[ -x "$XGO_BIN" ]] || die "xgo binary missing after update: $XGO_BIN"
  COMMIT="$(git -C "$ROOT_PATH" rev-parse HEAD 2>/dev/null || true)"
  VERSION="$(detect_version_from_xgo "$XGO_BIN")"
  write_meta "$name"
  write_config ""
  log "updated source toolchain '$name'"
}

update_standard() {
  local name="$1"
  load_meta "$name"

  local os
  os="$(uname -s | tr '[:upper:]' '[:lower:]')"
  if [[ "$os" == "darwin" ]]; then
    require_cmd brew
    brew upgrade xgo
  else
    require_cmd go
    go install github.com/goplus/xgo/cmd/xgo@latest
  fi

  local bin
  bin="$(command -v xgo || true)"
  [[ -n "$bin" ]] || die "xgo binary not found after standard update"

  XGO_BIN="$bin"
  VERSION="$(detect_version_from_xgo "$bin")"
  local detected_root=""
  detected_root="$(best_effort_detect_xgoroot "$bin" || true)"
  [[ -n "$detected_root" ]] && XGOROOT_VALUE="$detected_root"
  write_meta "$name"
  write_config ""
  log "updated standard toolchain '$name'"
}

cmd_toolchain_update() {
  local name="${1:-}"
  if [[ -z "$name" ]]; then
    name="$(default_toolchain || true)"
    [[ -n "$name" ]] || die "no default toolchain set"
  fi

  load_meta "$name"
  case "$KIND" in
    source) update_source "$name" ;;
    standard) update_standard "$name" ;;
    linked)
      warn "linked toolchain '$name' is externally managed; skipping update"
      ;;
    *) die "unknown toolchain kind for '$name': $KIND" ;;
  esac
}

cmd_toolchain_remove() {
  [[ $# -ge 1 ]] || die "toolchain remove requires <name>"
  local name="$1"
  shift

  local purge="false"
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --purge) purge="true"; shift ;;
      *) die "unknown option for toolchain remove: $1" ;;
    esac
  done

  load_meta "$name"

  if [[ "$purge" == "true" && "$MANAGED" == "true" ]]; then
    rm -rf "$ROOT_PATH"
    log "purged toolchain data: $ROOT_PATH"
  fi

  rm -f "$(meta_file "$name")"

  local cur
  cur="$(default_toolchain || true)"
  if [[ "$cur" == "$name" ]]; then
    write_config ""
    log "removed default toolchain '$name'; default cleared"
  else
    write_config "$cur"
  fi

  log "removed toolchain '$name'"
}

cmd_toolchain_list() {
  local as_json="false"
  if [[ $# -gt 0 ]]; then
    [[ "$1" == "--json" ]] || die "unknown option for toolchain list: $1"
    as_json="true"
  fi

  local cur
  cur="$(default_toolchain || true)"

  if [[ "$as_json" == "true" ]]; then
    printf '['
    local first="true"
    local n
    while IFS= read -r n; do
      [[ -n "$n" ]] || continue
      load_meta "$n"
      if [[ "$first" == "true" ]]; then
        first="false"
      else
        printf ','
      fi
      printf '\n  {"name":"%s","kind":"%s","path":"%s","default":%s,"version":"%s"}' \
        "$n" "$KIND" "$ROOT_PATH" "$([[ "$n" == "$cur" ]] && echo true || echo false)" "${VERSION:-}"
    done < <(meta_names)
    printf '\n]\n'
    return 0
  fi

  local any="false"
  local n
  while IFS= read -r n; do
    [[ -n "$n" ]] || continue
    any="true"
    load_meta "$n"
    if [[ "$n" == "$cur" ]]; then
      printf '* %s (default) [%s]\n' "$n" "$KIND"
    else
      printf '* %s [%s]\n' "$n" "$KIND"
    fi
    printf '  path: %s\n' "$ROOT_PATH"
    [[ -n "$VERSION" ]] && printf '  version: %s\n' "$VERSION"
    printf '  managed: %s\n' "$MANAGED"
  done < <(meta_names)

  if [[ "$any" == "false" ]]; then
    log "no installed toolchains"
  fi
}

find_project_toolchain() {
  local dir
  dir="$PWD"

  while :; do
    local file="$dir/$PROJECT_FILE"
    if [[ -f "$file" ]]; then
      awk -F'"' '/^toolchain[[:space:]]*=/{print $2; exit}' "$file"
      return 0
    fi

    [[ "$dir" == "/" ]] && break
    dir="$(dirname "$dir")"
  done

  return 1
}

resolve_toolchain_name() {
  local cli_toolchain="${1:-}"
  if [[ -n "$cli_toolchain" ]]; then
    printf '%s\n' "$cli_toolchain"
    return 0
  fi

  if [[ -n "${XGO_TOOLCHAIN:-}" ]]; then
    printf '%s\n' "$XGO_TOOLCHAIN"
    return 0
  fi

  local project
  project="$(find_project_toolchain || true)"
  if [[ -n "$project" ]]; then
    printf '%s\n' "$project"
    return 0
  fi

  local def
  def="$(default_toolchain || true)"
  [[ -n "$def" ]] || die "no toolchain resolved; set default via: xgoup default <name>"
  printf '%s\n' "$def"
}

resolve_exec_context() {
  local selected
  selected="$(resolve_toolchain_name "${1:-}")"
  load_meta "$selected"
  [[ -x "$XGO_BIN" ]] || die "xgo binary is missing for '$selected': $XGO_BIN"
}

cmd_default() {
  [[ $# -eq 1 ]] || die "default requires <name>"
  set_default_toolchain "$1"
}

cmd_which() {
  local toolchain=""
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --toolchain)
        [[ $# -ge 2 ]] || die "--toolchain requires value"
        toolchain="$2"
        shift 2
        ;;
      *) die "unknown option for which: $1" ;;
    esac
  done

  resolve_exec_context "$toolchain"
  printf '%s\n' "$XGO_BIN"
}

cmd_env() {
  local toolchain=""
  local shell_name="sh"

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --toolchain)
        [[ $# -ge 2 ]] || die "--toolchain requires value"
        toolchain="$2"
        shift 2
        ;;
      --shell)
        [[ $# -ge 2 ]] || die "--shell requires value"
        shell_name="$2"
        shift 2
        ;;
      *) die "unknown option for env: $1" ;;
    esac
  done

  resolve_exec_context "$toolchain"
  local bin_dir
  bin_dir="$(dirname "$XGO_BIN")"

  case "$shell_name" in
    sh|zsh|bash)
      [[ -n "$XGOROOT_VALUE" ]] && printf 'export XGOROOT="%s"\n' "$XGOROOT_VALUE"
      printf 'export PATH="%s:$PATH"\n' "$bin_dir"
      ;;
    fish)
      [[ -n "$XGOROOT_VALUE" ]] && printf 'set -gx XGOROOT "%s";\n' "$XGOROOT_VALUE"
      printf 'set -gx PATH "%s" $PATH;\n' "$bin_dir"
      ;;
    powershell|pwsh)
      [[ -n "$XGOROOT_VALUE" ]] && printf '$env:XGOROOT = "%s"\n' "$XGOROOT_VALUE"
      printf '$env:PATH = "%s;" + $env:PATH\n' "$bin_dir"
      ;;
    *) die "unsupported shell: $shell_name" ;;
  esac
}

cmd_doctor() {
  local failures=0

  ensure_dirs
  [[ -f "$CONFIG_FILE" ]] || write_config ""

  if command -v git >/dev/null 2>&1; then
    log "git: ok ($(command -v git))"
  else
    warn "git: missing"
  fi

  if command -v go >/dev/null 2>&1; then
    log "go: ok ($(command -v go))"
  else
    warn "go: missing"
  fi

  log "xgoup home: $TOOL_HOME"
  log "config: $CONFIG_FILE"

  local def
  def="$(default_toolchain || true)"
  if [[ -z "$def" ]]; then
    warn "default toolchain not set"
    failures=$((failures + 1))
  elif ! have_toolchain "$def"; then
    err "default toolchain '$def' is not registered"
    failures=$((failures + 1))
  else
    load_meta "$def"
    if [[ -x "$XGO_BIN" ]]; then
      log "default xgo: $XGO_BIN"
    else
      err "default xgo binary missing: $XGO_BIN"
      failures=$((failures + 1))
    fi
  fi

  local n
  while IFS= read -r n; do
    [[ -n "$n" ]] || continue
    load_meta "$n"
    if [[ ! -x "$XGO_BIN" ]]; then
      err "toolchain '$n' has missing xgo binary: $XGO_BIN"
      failures=$((failures + 1))
    fi
  done < <(meta_names)

  if [[ "$failures" -eq 0 ]]; then
    log "doctor passed"
  else
    die "doctor found $failures issue(s)"
  fi
}

cmd_toolchain() {
  [[ $# -ge 1 ]] || die "toolchain requires a subcommand"
  local sub="$1"
  shift

  case "$sub" in
    install) cmd_toolchain_install "$@" ;;
    update) cmd_toolchain_update "$@" ;;
    list) cmd_toolchain_list "$@" ;;
    remove) cmd_toolchain_remove "$@" ;;
    *) die "unknown toolchain subcommand: $sub" ;;
  esac
}

cmd_install_alias() {
  warn "'xgoup install' is now preferred; `xgoup toolchain install` is kept for grouping"
  [[ $# -ge 1 ]] || die "install requires <name>"
  cmd_toolchain_install "$@"
}

cmd_update_alias() {
  warn "'xgoup update' is deprecated; use: xgoup toolchain update"
  cmd_toolchain_update "$@"
}

cmd_list_alias() {
  warn "'xgoup list' is deprecated; use: xgoup toolchain list"
  cmd_toolchain_list "$@"
}

main() {
  [[ $# -ge 1 ]] || {
    usage
    exit 1
  }

  local cmd="$1"
  shift

  case "$cmd" in
    init) cmd_init "$@" ;;
    toolchain) cmd_toolchain "$@" ;;
    default) cmd_default "$@" ;;
    which) cmd_which "$@" ;;
    env) cmd_env "$@" ;;
    doctor) cmd_doctor "$@" ;;
    install) cmd_install_alias "$@" ;;
    update) cmd_update_alias "$@" ;;
    list) cmd_list_alias "$@" ;;
    remove) cmd_toolchain_remove "$@" ;;
    -V|--version) echo "$XGOUP_VERSION" ;;
    -h|--help|help) usage ;;
    *)
      usage
      die "unknown command: $cmd"
      ;;
  esac
}

main "$@"
